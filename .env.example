# ---------------------------------------------------------------------------
# WeEnable — environment variables
# Copy to .env.local for local dev. Set the same in the Vercel dashboard.
# ---------------------------------------------------------------------------

# Public site URL (no trailing slash). Used for canonical URLs, OG tags, sitemap.
# Production: https://weenable.org
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Phase 2 seams (not used in Phase 1; here so deploys are ready) ---------

# Stripe (donation checkout — Phase 2)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Email / CRM provider for form + newsletter delivery (Phase 2)
# EMAIL_PROVIDER_API_KEY=""
# NEWSLETTER_PROVIDER_API_KEY=""

# Auth (portal sign-in — Phase 2, Auth.js-ready)
# AUTH_SECRET=""
