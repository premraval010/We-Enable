# ---------------------------------------------------------------------------
# WeEnable — environment variables
# Copy to .env.local for local dev. Set the same in the Vercel dashboard.
# ---------------------------------------------------------------------------

# Public site URL (no trailing slash). Used for canonical URLs, OG tags, sitemap.
# Production: https://weenable.org
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Email delivery (Resend) — powers all form + newsletter notifications ---
# Get a key at https://resend.com. Without it, form submissions are logged to
# the server (visible in Vercel Runtime Logs) instead of emailed.
RESEND_API_KEY=""
# Verified sender. Until weenable.org is verified in Resend, leave this unset to
# use Resend's onboarding sender. Once verified: "WeEnable <noreply@weenable.org>"
# RESEND_FROM="WeEnable <noreply@weenable.org>"
# Optional: route ALL notifications to one address (handy before domain
# verification, when Resend only lets you send to your own account email).
# NOTIFICATIONS_TO="you@example.com"

# --- Later-phase seams (here so deploys are ready) --------------------------

# Stripe (online donation checkout — later phase)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Auth (portals / sign-in — later phase, Auth.js-ready)
# AUTH_SECRET=""
